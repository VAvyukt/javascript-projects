// 1. Declare the coordinates variable
let coordinates;

function setup() {
    new Canvas(450, 450);

    // 2. Create the coordinates in the setup() function
    mouseCoordinates();
}

function draw() {
    clear();
    background("#f0d36c");
    
    // 3. Update the coordinates as mouse moves in the draw() function
    coordinates.text = round(mouse.x, 1) + ', ' + round(mouse.y, 1);
}

// 4. Helper function that creates the coordinates and adds them to the canvas
function mouseCoordinates() {
    coordinates = new Sprite();
    coordinates.color = 'white';
    coordinates.width = 80;
    coordinates.height = 20;
    coordinates.x = width - coordinates.width / 2 - 5;
    coordinates.y = coordinates.height / 2 + 5;
    coordinates.collider = 'none';
}